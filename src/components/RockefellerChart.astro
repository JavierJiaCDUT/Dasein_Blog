---
type RawPoint = [string, number | null];
type Point = {
  actual: boolean;
  label: string;
  value: number;
};

const rawData: RawPoint[] = [
  ["1900", 200],
  ["1901", null],
  ["1902", null],
  ["1903", null],
  ["1904", null],
  ["1905", null],
  ["1906", null],
  ["1907", null],
  ["1908", null],
  ["1909", null],
  ["1910", null],
  ["1911", 814],
  ["1912", 873],
  ["1913", 907],
  ["1914", 904],
  ["1915", 1282],
  ["1916", 1482],
  ["1917", 1163],
];

function interpolateSeries(data: RawPoint[]): Point[] {
  const result: Point[] = [];

  for (let index = 0; index < data.length; index += 1) {
    const [label, value] = data[index];

    if (value !== null) {
      result.push({ actual: true, label, value });
      continue;
    }

    let previousIndex = index - 1;
    while (previousIndex >= 0 && data[previousIndex][1] === null) previousIndex -= 1;

    let nextIndex = index + 1;
    while (nextIndex < data.length && data[nextIndex][1] === null) nextIndex += 1;

    if (previousIndex >= 0 && nextIndex < data.length) {
      const startValue = data[previousIndex][1] as number;
      const endValue = data[nextIndex][1] as number;
      const progress = (index - previousIndex) / (nextIndex - previousIndex);
      const interpolatedValue = startValue + (endValue - startValue) * progress;

      result.push({
        actual: false,
        label,
        value: Math.round(interpolatedValue),
      });
    }
  }

  return result;
}

const points = interpolateSeries(rawData);
const width = 720;
const height = 360;
const padding = { bottom: 42, left: 56, right: 16, top: 24 };
const chartWidth = width - padding.left - padding.right;
const chartHeight = height - padding.top - padding.bottom;
const minY = 0;
const maxY = 1600;
const xStep = chartWidth / Math.max(points.length - 1, 1);
const baselineY = padding.top + chartHeight;

const getX = (index: number) => padding.left + index * xStep;
const getY = (value: number) =>
  padding.top + ((maxY - value) / (maxY - minY)) * chartHeight;

const chartPoints = points.map((point, index) => ({
  ...point,
  x: getX(index),
  y: getY(point.value),
}));

const firstPoint = chartPoints[0];
const lastPoint = chartPoints[chartPoints.length - 1];
const linePath = chartPoints
  .map((point, index) => `${index === 0 ? "M" : "L"} ${point.x} ${point.y}`)
  .join(" ");
const areaPath = `${linePath} L ${lastPoint.x} ${baselineY} L ${firstPoint.x} ${baselineY} Z`;
const xTicks = chartPoints.filter((point, index) => {
  const year = Number(point.label);
  return year % 5 === 0 || index === chartPoints.length - 1;
});
const yTicks = [0, 400, 800, 1200, 1600].map((value) => ({
  label: `$${value}M`,
  value,
  y: getY(value),
}));
---

<figure class="rockefeller-chart-wrapper">

  <div class="chart-container">
    <svg
      aria-labelledby="rockefeller-chart-title rockefeller-chart-desc"
      class="chart-svg"
      role="img"
      viewBox={`0 0 ${width} ${height}`}
    >
      <title id="rockefeller-chart-title">
        John D. Rockefeller Senior's estimated net worth from 1900 to 1917
      </title>
      <desc id="rockefeller-chart-desc">
        A line chart showing Rockefeller's estimated net worth rising from about
        200 million dollars in 1900 to a peak above 1.4 billion in 1916 before
        easing in 1917.
      </desc>

      <defs>
        <linearGradient id="rockefeller-chart-fill" x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color="var(--chart-fill-start)" />
          <stop offset="100%" stop-color="var(--chart-fill-end)" />
        </linearGradient>
      </defs>

      {yTicks.map((tick) => (
        <>
          <line
            class="grid-line"
            x1={padding.left}
            x2={width - padding.right}
            y1={tick.y}
            y2={tick.y}
          />
          <text class="axis-label" text-anchor="end" x={padding.left - 8} y={tick.y + 4}>
            {tick.label}
          </text>
        </>
      ))}

      <line
        class="axis-line"
        x1={padding.left}
        x2={padding.left}
        y1={padding.top}
        y2={baselineY}
      />
      <line
        class="axis-line"
        x1={padding.left}
        x2={width - padding.right}
        y1={baselineY}
        y2={baselineY}
      />

      {xTicks.map((tick) => (
        <>
          <line
            class="axis-line"
            x1={tick.x}
            x2={tick.x}
            y1={baselineY}
            y2={baselineY + 4}
          />
          <text class="axis-label" text-anchor="middle" x={tick.x} y={baselineY + 20}>
            {tick.label}
          </text>
        </>
      ))}

      <path d={areaPath} fill="url(#rockefeller-chart-fill)" />
      <path
        class="line-path"
        d={linePath}
        fill="none"
        pathLength="100"
        stroke="var(--chart-line)"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="3"
      />

      {chartPoints.filter((point) => point.actual).map((point) => (
        <circle
          cx={point.x}
          cy={point.y}
          fill="var(--chart-line)"
          r="4"
          stroke="var(--chart-surface)"
          stroke-width="1.5"
        >
          <title>{`${point.label}: $${point.value}M`}</title>
        </circle>
      ))}
    </svg>
  </div>
  <p class="chart-note">
    Dots mark years with explicit historical estimates; intervening years are smoothed between them.
  </p>
  <p class="chart-source">
    Source: Bloomberg analysis based on historical records, including donation tallies and stock performance; Standard Oil data provided by Finaeon, Inc.
  </p>
</figure>

<style>
  .rockefeller-chart-wrapper {
    --chart-fill-end: rgba(180, 83, 9, 0);
    --chart-fill-start: rgba(180, 83, 9, 0.14);
    --chart-grid: rgba(15, 23, 42, 0.08);
    --chart-line: #b45309;
    --chart-muted: rgba(15, 23, 42, 0.6);
    --chart-surface: var(--color-surface, #fff);
    margin: 2rem 0;
    padding: 1.25rem 1.25rem 0.75rem;
    border: 1px solid var(--color-border, rgba(0, 0, 0, 0.1));
    border-radius: 0.75rem;
    background: var(--chart-surface);
  }

  :global(html.dark) .rockefeller-chart-wrapper {
    --chart-fill-end: rgba(245, 158, 11, 0);
    --chart-fill-start: rgba(245, 158, 11, 0.24);
    --chart-grid: rgba(255, 255, 255, 0.1);
    --chart-line: #f59e0b;
    --chart-muted: rgba(255, 255, 255, 0.62);
    --chart-surface: var(--color-surface, #111827);
  }

  @media (prefers-color-scheme: dark) {
    .rockefeller-chart-wrapper {
      --chart-fill-end: rgba(245, 158, 11, 0);
      --chart-fill-start: rgba(245, 158, 11, 0.24);
      --chart-grid: rgba(255, 255, 255, 0.1);
      --chart-line: #f59e0b;
      --chart-muted: rgba(255, 255, 255, 0.62);
      --chart-surface: var(--color-surface, #111827);
    }
  }

  .chart-subtitle {
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--color-ink, #111);
    line-height: 1.4;
  }

  .chart-container {
    width: 100%;
  }

  .chart-svg {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .grid-line,
  .axis-line {
    stroke: var(--chart-grid);
    vector-effect: non-scaling-stroke;
  }

  .line-path {
    vector-effect: non-scaling-stroke;
  }

  .axis-label {
    fill: var(--chart-muted);
    font-size: 11px;
  }

  .chart-note,
  .chart-source {
    margin: 0.75rem 0 0;
    font-size: 0.72rem;
    color: var(--color-muted, #888);
  }

  .chart-note {
    margin-top: 0.9rem;
  }

  .chart-source {
    margin-top: 0.2rem;
  }
</style>
